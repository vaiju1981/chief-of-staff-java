# Copy to .env and fill in.  .env is gitignored; start.sh sources it.

# Postgres password (RAG store). Must match docker/compose.yml.
DATABASE_PASSWORD=cos_local_dev

# GitHub personal access token — enables the code agent's GitHub issue tools (via MCP).
# Create one at https://github.com/settings/tokens (repo scope). Leave blank to disable.
GITHUB_TOKEN=

# Tavily API key — enables the researcher's web search (via MCP).
# Get one at https://tavily.com. Leave blank to disable.
TAVILY_API_KEY=
